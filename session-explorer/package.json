{
	"name": "dot-mi-session-explorer",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -k -n api,vite -c blue,green \"npm run dev:api\" \"npm run dev:vite\"",
		"dev:api": "tsx watch server.ts",
		"dev:vite": "vite",
		"build": "vite build",
		"start": "SESSION_EXPLORER_SERVE_STATIC=1 tsx server.ts",
		"check": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.0",
		"@mariozechner/mini-lit": "^0.2.0",
		"@mariozechner/pi-agent-core": "0.66.1",
		"@mariozechner/pi-ai": "0.66.1",
		"@mariozechner/pi-coding-agent": "0.66.1",
		"@mariozechner/pi-web-ui": "0.66.1",
		"@tailwindcss/vite": "^4.1.17",
		"hono": "^4.11.3",
		"lit": "^3.3.1"
	},
	"devDependencies": {
		"@types/node": "^22.19.1",
		"concurrently": "^9.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.7.3",
		"vite": "^7.1.6"
	}
}
