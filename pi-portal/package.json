{
	"name": "pi-portal",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -k -n api,vite -c blue,green \"npm run dev:api\" \"npm run dev:vite\"",
		"dev:api": "tsx watch server.ts",
		"dev:vite": "vite",
		"build": "tsc --noEmit && vite build",
		"start": "PI_PORTAL_SERVE_STATIC=1 tsx server.ts",
		"check": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.0",
		"hono": "^4.11.3",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.19.1",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.7.3",
		"vite": "^6.0.0"
	}
}
